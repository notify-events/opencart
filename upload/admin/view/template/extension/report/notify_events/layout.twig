{{ header }}{{ column_left }}

<div id="content">

  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">

        {% if add_btn_link %}
          <a href="{{ add_btn_link }}" data-toggle="tooltip" title="{{ add_btn_text }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        {% endif %}

        {% if add_btn_target_modal %}
            <button type="button" data-toggle="modal" title="{{ add_btn_text }}" data-target="{{ add_btn_target_modal }}" class="btn btn-primary"><i class="fa fa-plus"></i></button>
        {% endif %}

        {% if delete_target_form %}
          <button type="button" data-toggle="tooltip" title="{{ delete_btn_text }}" class="btn btn-danger" onclick="confirm('{{ delete_confirm }}') ? $('{{ delete_target_form }}').submit() : false;"><i class="fa fa-trash-o"></i></button>
        {% endif %}

        {% if back_btn_link %}
          <a href="{{ back_btn_link }}" data-toggle="tooltip" title="{{ back_btn_text }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
        {% endif %}

      </div>
      <h1>{{ layout_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">

    {% for alert in alerts %}
      <div class="alert {{ alert.class }} alert-dismissible"><i class="fa {{ alert.icon }}"></i> {{ alert.text }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endfor %}

    <ul class="nav nav-tabs">
      {% for tab in layout_tabs %}
        <li class="{{ tab.class }}"><a href="{{ tab.link }}">{{ tab.title }}</a></li>
      {% endfor %}
    </ul>

    {{ page_content }}

  </div>

</div>

{{ footer }}
